{
    "name": "mgamadeus/ddd-ai",
    "description": "AI model management, prompt system, and Argus AI integration traits for mgamadeus/ddd",
    "minimum-stability": "stable",
    "license": "MIT",
    "version": "1.0.1",
    "authors": [
        {
            "name": "Marius-Eugen Gerdan",
            "email": "marius@gerdan.net"
        }
    ],
    "require": {
        "mgamadeus/ddd-argus": "^1.0",
        "mgamadeus/ddd": "^2.10"
    },
    "autoload": {
        "psr-4": {
            "DDD\\Modules\\AI\\": "src/",
            "DDD\\Domain\\AI\\": "src/Domain/AI/",
            "DDD\\Domain\\Batch\\Services\\": "src/Domain/Batch/Services/",
            "DDD\\Presentation\\Api\\Batch\\AI\\": "src/Presentation/Api/Batch/AI/"
        }
    },
    "extra": {
        "ddd-module": "DDD\\Modules\\AI\\AIModule"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
